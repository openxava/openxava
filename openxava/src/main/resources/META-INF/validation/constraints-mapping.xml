    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/validation/mapping
                        https://jakarta.ee/xml/ns/validation/mapping-3.0.xsd"
    version="3.0">
